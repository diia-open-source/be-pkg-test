{
    "name": "@diia-inhouse/test",
    "version": "8.0.0",
    "type": "module",
    "description": "test-utils",
    "main": "dist/index.js",
    "author": "Diia",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsdown",
        "prebuild": "rimraf dist",
        "prepare": "npm run build",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "oxlint && oxfmt --check .",
        "lint-fix": "oxlint --fix && oxfmt .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "files": [
        "dist",
        "vitest"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./vitest": {
            "default": "./vitest/extend-expect.ts"
        },
        "./package.json": "./package.json"
    },
    "engines": {
        "node": ">=24"
    },
    "keywords": [],
    "dependencies": {
        "@diia-inhouse/design-system": "4.0.3",
        "@vitest/expect": "4.1.5",
        "glob": "13.0.6",
        "lodash": "4.18.1",
        "luxon": "3.7.2",
        "nock": "14.0.15",
        "superstruct": "2.0.2",
        "type-fest": "4.41.0",
        "vitest": "4.1.5"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "7.0.0",
        "@diia-inhouse/oxc-config": "1.9.3",
        "@diia-inhouse/types": "13.1.1",
        "@types/lodash": "4.17.24",
        "@types/luxon": "3.7.1",
        "bson": "7.2.0",
        "drizzle-orm": "0.45.2",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "mongoose": "8.20.4",
        "oxfmt": "0.48.0",
        "oxlint": "1.63.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "tsdown": "0.22.0",
        "typescript": "5.9.3"
    },
    "peerDependencies": {
        "@diia-inhouse/types": ">=13.1.0",
        "bson": ">=6.2.0",
        "drizzle-orm": ">=0.38.2",
        "mongoose": ">=8.0.0"
    },
    "peerDependenciesMeta": {
        "drizzle-orm": {
            "optional": true
        },
        "mongoose": {
            "optional": true
        }
    },
    "resolutions": {
        "@babel/traverse": "7.25.9"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    },
    "repository": "https://github.com/diia-open-source/be-pkg-test",
    "license": "SEE LICENCE IN LICENCE.md"
}
